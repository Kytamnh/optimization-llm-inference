#!/usr/bin/env bash
# Template for site-local secrets. Copy to env.sh and edit:
#   $ cp env.sh.example env.sh
#   $ chmod 600 env.sh
#   $ $EDITOR env.sh
#
# env.sh is in .gitignore and must NEVER be committed. The combined and
# llm_agent sbatch scripts auto-source ${PROJECT_ROOT}/env.sh if it exists,
# so anything you export here is visible to the running job.

# -----------------------------------------------------------------------------
# Anthropic API key (required only for the LLM-Agent stage, methods 1.3 + 5)
# -----------------------------------------------------------------------------
# Without this set, the LLM-Agent stage is skipped (the other methods still run).
# Get a key at https://console.anthropic.com/. Cost guidance: a full 30-trial
# Opus 4.7 + adaptive-thinking xhigh run costs ~$10-15 in API charges.
# export ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Hugging Face token (only needed if you swap NousResearch/* for the gated
# meta-llama/* originals, or for any other gated model)
# -----------------------------------------------------------------------------
# export HF_TOKEN=hf_...
